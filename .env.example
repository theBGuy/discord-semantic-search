# ─────────────────────────────────────────────────────────────────────────────
# Discord Semantic Search — environment
# Copy to `.env` and fill in. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord ──────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications  (Bot > Token)
DISCORD_TOKEN=
# Application (client) ID  (General Information > Application ID)
DISCORD_CLIENT_ID=
# Optional: register slash commands instantly to this guild during development.
# Leave empty in production to use GLOBAL command registration.
DISCORD_DEV_GUILD_ID=

# Skip messages authored by bots/webhooks when indexing (true/false)
SKIP_BOT_MESSAGES=true
# Run historical backfill automatically on bot startup (true/false).
# Default false — prefer triggering with the /index slash command.
BACKFILL_ON_START=false
# How many channels/threads to crawl concurrently during backfill (1-10).
BACKFILL_CONCURRENCY=3

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=discord
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=discord_search
# Optional: full connection string overrides the parts above.
# DATABASE_URL=postgres://discord:change-me-please@postgres:5432/discord_search

# ── Ollama ───────────────────────────────────────────────────────────────────
# Client base URL the services call. Defaults to the bundled local container.
#   Local container:   http://ollama:11434      (run with `--profile local-ollama`)
#   Remote Ollama:     http://192.168.x.x:11434 (a host on your LAN — see notes)
#   Ollama Cloud:      https://ollama.com
# Remote/LAN notes: use the host's IP (NOT localhost or host.docker.internal — those
# resolve inside the container, not to your Ollama box). The remote Ollama must bind
# 0.0.0.0 (set OLLAMA_HOST=0.0.0.0 on it) and have the models pre-pulled (the bundled
# model-puller only runs with --profile local-ollama). Run plain `docker compose up -d`.
# Embeddings ALWAYS use OLLAMA_BASE_URL (kept local — high volume). Point this at your
# local/LAN Ollama that has the embedding model pulled.
OLLAMA_BASE_URL=http://ollama:11434
# Optional API key for OLLAMA_BASE_URL — sent as `Authorization: Bearer <key>`.
OLLAMA_API_KEY=

# Chat/RAG cloud endpoint (optional). When set, /ask /summarize /digest /kb use this as
# PRIMARY and fall back to OLLAMA_BASE_URL on a session limit (HTTP 429) for the cooldown.
#   OLLAMA_CLOUD_URL=https://ollama.com
#   OLLAMA_CLOUD_API_KEY=your-cloud-key
OLLAMA_CLOUD_URL=
OLLAMA_CLOUD_API_KEY=
# How long to stay on local after the cloud reports a session limit (ms, default 5 min).
OLLAMA_CLOUD_COOLDOWN_MS=300000

# ── Embedding model (runs on OLLAMA_BASE_URL) ────────────────────────────────
# EMBED_DIM must match the model's output dimension. The vector column is created at
# 768 by migration and auto-set to EMBED_DIM on first migrate (when empty). To CHANGE
# the model after you have data: set EMBED_MODEL + EMBED_DIM here, then run
# `pnpm reembed` (re-embeds stored text at the new dimension — no Discord re-crawl).
# pgvector's HNSW index supports up to 2000 dimensions.
#
# Default — qwen3-embedding:0.6b (1024 dims, multilingual). No retrieval prefixes.
EMBED_MODEL=qwen3-embedding:0.6b
EMBED_DIM=1024
EMBED_DOC_PREFIX=
EMBED_QUERY_PREFIX=
# Optional, may improve retrieval (qwen3 query instruction, applied verbatim):
# EMBED_QUERY_PREFIX=Instruct: Retrieve Discord messages relevant to the query. Query:
#   (qwen3-embedding 4b=2560 and 8b=4096 EXCEED the 2000-dim HNSW limit — use 0.6b.)
#
# Alternative — nomic-embed-text (768 dims, 8192-token context, asymmetric prefixes):
#   EMBED_MODEL=nomic-embed-text
#   EMBED_DIM=768
#   EMBED_DOC_PREFIX=search_document:
#   EMBED_QUERY_PREFIX=search_query:
#
# Alternative — mxbai-embed-large (1024 dims):
#   EMBED_MODEL=mxbai-embed-large
#   EMBED_DIM=1024
#   EMBED_DOC_PREFIX=
#   EMBED_QUERY_PREFIX=Represent this sentence for searching relevant passages:

# ── Reasoning (RAG) model ────────────────────────────────────────────────────
# Primary chat model (used on the cloud endpoint). The ACTIVE model is set at runtime
# via `/model` (stored in the DB); this is the default until one is set.
CHAT_MODEL=qwen2.5:7b
# Optional smaller model used when chat falls back to the LOCAL endpoint. Leave empty
# to use the same model on both. Set/override at runtime with `/model set:<m> scope:fallback`.
CHAT_MODEL_LOCAL=
# Context window for the reasoning model during RAG.
NUM_CTX=8192

# ── Search / RAG tuning ──────────────────────────────────────────────────────
FTS_LANG=english
SEARCH_TOP_N=10
RAG_TOP_K=25
# Candidate oversample for ANN: K = SEARCH_TOP_N * ANN_OVERSAMPLE
ANN_OVERSAMPLE=20
HNSW_EF_SEARCH=60

# ── Chunking ─────────────────────────────────────────────────────────────────
# Conservative, well under nomic-embed-text's served context. Char-based approx.
CHUNK_MAX_CHARS=1800
CHUNK_OVERLAP_CHARS=200
# Cap chunks per single embedding job (protects the queue visibility window).
MAX_CHUNKS_PER_JOB=64
# Embedding jobs processed concurrently per worker (speeds up backfill). For a real
# speedup also raise OLLAMA_NUM_PARALLEL on the embedding Ollama to match.
WORKER_CONCURRENCY=3

# ── Attachments (Phase 2) ────────────────────────────────────────────────────
# Skip attachments larger than this many bytes (default 10 MiB).
ATTACHMENT_MAX_BYTES=10485760

# ── OCR (Phase 3) ────────────────────────────────────────────────────────────
# Extract text from image attachments (screenshots) via the bundled Tesseract.
OCR_ENABLED=true
# Tesseract language(s). The image ships "eng"; add tesseract-ocr-<lang> packages to
# the Dockerfile for others (e.g. OCR_LANG=eng+deu).
OCR_LANG=eng
# Ignore OCR results shorter than this many characters (skip text-free images).
OCR_MIN_CHARS=8
# Kill a single OCR run after this many ms.
OCR_TIMEOUT_MS=60000

# ── Services ─────────────────────────────────────────────────────────────────
# Internal URL the bot uses to reach search-api (compose network).
SEARCH_API_URL=http://search-api:3000
SEARCH_API_PORT=3000

# ── Governance ───────────────────────────────────────────────────────────────
# Operator user IDs (comma-separated): admin in EVERY server, can't be locked out, and
# the only ones who can run /model. Put your own ID here. Per-server admins are added
# at runtime with /admin add. (Developer Mode → right-click yourself → Copy User ID.)
BOOTSTRAP_ADMIN_IDS=
# Default per-user rate limit (commands/hour; 0 = unlimited). Admins are exempt; each
# server can override via /admin ratelimit. Access mode defaults to "allowlist" per
# server (set via /admin access) — only admins + allowed roles/users until granted.
RATE_LIMIT_PER_HOUR=30

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
